## GEMINI HELPERS
# Usage: g_apply "add logging" main.py
g_apply() {
    local prompt="$1"
    local file="$2"
    cat "$file" | gemini -m "$GEMINI_MODEL" "$prompt"
}

# Usage: g_refactor "refactor to use async" main.py
g_refactor() {
    local prompt="$1"
    local file="$2"
    local tmp_file=$(mktemp)

    cat "$file" | gemini -m "$GEMINI_MODEL" "$prompt. Return ONLY the code." > "$tmp_file"

    echo "--- Diff for $file ---"
    diff -u "$file" "$tmp_file"

    read -p "Apply changes? (y/n) " -n 1 -r
    echo
    if [[ $REPLY =~ ^[Yy]$ ]]; then
        mv "$tmp_file" "$file"
    else
        rm "$tmp_file"
    fi
}

# Usage: g_explain main.py
g_explain() {
    local target="${1:-/dev/stdin}"
    cat "$target" | gemini -m "$GEMINI_MODEL" "Explain what this does in 2 concise sentences."
}

# Usage: g_commit
g_commit() {
    local msg=$(git diff --cached | gemini -m "$GEMINI_MODEL" "Write a concise, conventional commit message for these changes. Return ONLY the message.")
    git commit -m "$msg"
}

# Usage: g_fix main.py "add a timeout parameter to the request call"
g_fix() {
  local file=$1
  local task=$2
  gemini -m "$GEMINI_MODEL" --yolo -p "Update $file: $task. Output ONLY the modified code. No conversation."
}

# Fast feature adder for specific files
# Usage: g_add_to main.py "add a retry decorator to the fetch function"
g_add_to() {
    local file=$1
    local feature=$2
    gemini -m "$GEMINI_MODEL" --yolo -p "File: $file. Feature: $feature. Rewrite the file with this feature. Use concise logic. Code only."
}

# Usage: g_ask main.py "what methods are defined here?"
g_ask() {
    local file="$1"
    local question="$2"
    cat "$file" | gemini -m "$GEMINI_MODEL" "Analyze the following file and answer this question: $question"
}
# Interactive model selection
# Usage: g_select
g_select() {
    local models=($(g_models))
    echo "Select a Gemini model:"
    PS3="Enter choice [1-${#models[@]}]: "
    select opt in "${models[@]}" "Quit"; do
        if [[ "$opt" == "Quit" ]]; then
            echo "Selection cancelled."
            break
        elif [[ -n "$opt" ]]; then
            export GEMINI_MODEL="$opt"
            echo "GEMINI_MODEL set to: $GEMINI_MODEL"
            break
        else
            echo "Invalid option $REPLY"
        fi
    done
}

